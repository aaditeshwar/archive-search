# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=archive_search

# Embeddings: openai | sentence-transformers | ollama
OPENAI_API_KEY=
EMBEDDING_MODEL=ollama
# For sentence-transformers: SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2
# For Ollama:
OLLAMA_EMBED_MODEL=nomic-embed-text
# Vector index dimension: 1536 (OpenAI), 384 (all-MiniLM-L6-v2), 768 (nomic-embed-text)
EMBEDDING_DIMENSION=768

# LLM for generating answers: openai | ollama (used when ENABLE_LLM_ANSWER=true)
ENABLE_LLM_ANSWER=true
LLM_PROVIDER=ollama
# For Ollama (defaults shown):
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434
# For OpenAI: set OPENAI_API_KEY and LLM_PROVIDER=openai

# Optional: Redis for session store (leave empty for in-memory)
REDIS_URL=

# Google Group to index
GROUP_URL=https://groups.google.com/g/core-stack-nrm/
TOPIC_URLS_FILE=data/topic_urls.txt
