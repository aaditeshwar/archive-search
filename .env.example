# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=archive_search

# Embeddings: OpenAI (set OPENAI_API_KEY) or local (set EMBEDDING_MODEL=sentence-transformers)
OPENAI_API_KEY=
EMBEDDING_MODEL=openai
# For local: EMBEDDING_MODEL=sentence-transformers and optionally:
# SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2

# Vector index dimension (1536 for text-embedding-3-small, 384 for all-MiniLM-L6-v2)
EMBEDDING_DIMENSION=1536

# Optional: LLM for generating answers (OpenAI)
# OPENAI_API_KEY used for chat completions if ENABLE_LLM_ANSWER=true
ENABLE_LLM_ANSWER=false

# Optional: Redis for session store (leave empty for in-memory)
REDIS_URL=

# Google Group to index (default CoRE stack NRM)
GROUP_URL=https://groups.google.com/g/core-stack-nrm/

# List of topic URLs
TOPIC_URLS_FILE=data/topic_urls.txt